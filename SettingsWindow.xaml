<Window x:Class="BTDSys.PeerCtrl.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BTDSys.PeerCtrl"
        Title="BTDSys PeerCtrl – Assignment Settings"
        Width="840" Height="660"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E" Foreground="#DDDDDD">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DDDDDD"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#DDDDDD"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"   Value="#3A3A3A"/>
            <Setter Property="Foreground"   Value="#DDDDDD"/>
            <Setter Property="BorderBrush"  Value="#555"/>
            <Setter Property="Padding"      Value="8,3"/>
            <Setter Property="MinWidth"     Value="64"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="#2D2D2D"/>
            <Setter Property="Foreground"  Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background"  Value="#252525"/>
            <Setter Property="Foreground"  Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"       Value="#DDDDDD"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="#2D2D2D"/>
            <Setter Property="Foreground"  Value="#DDDDDD"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="Width"       Value="64"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"  Value="#AAAAAA"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ====================================================
             Row 0 – main content (assignment list + editor)
             ==================================================== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: track selector + assignment list ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,4">
                    <TextBlock Text="Track:" Margin="0,0,0,2"/>
                    <ComboBox x:Name="TrackCombo"
                              SelectionChanged="TrackCombo_SelectionChanged"/>
                </StackPanel>

                <!-- Assignment list – items are TrackAssignment objects;
                     we show their Label property via a DataTemplate -->
                <ListBox Grid.Row="1"
                         x:Name="AssignmentList"
                         SelectionChanged="AssignmentList_SelectionChanged"
                         Margin="0,0,0,4">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="Add"    Click="BtnAdd_Click"    Margin="0,0,4,0"/>
                    <Button Content="Delete" Click="BtnDelete_Click" Margin="0,0,4,0"/>
                    <Button Content="Clear"  Click="BtnClear_Click"/>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="#444"/>

            <!-- ── RIGHT: editing controls ── -->
            <ScrollViewer Grid.Column="2" Margin="8,0,0,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Target -->
                    <GroupBox Header="Target" Margin="0,0,0,6">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="85"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Machine:"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1"
                                       x:Name="MachineCombo"
                                       SelectionChanged="MachineCombo_SelectionChanged"
                                       Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Parameter:"/>
                            <ComboBox  Grid.Row="1" Grid.Column="1"
                                       x:Name="ParamCombo"
                                       SelectionChanged="ParamCombo_SelectionChanged"
                                       Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Track:"/>
                            <ComboBox  Grid.Row="2" Grid.Column="1"
                                       x:Name="TargetTrackCombo"
                                       SelectionChanged="TargetTrackCombo_SelectionChanged"
                                       Margin="0,2"/>
                        </Grid>
                    </GroupBox>

                    <!-- MIDI CC -->
                    <GroupBox Header="MIDI CC" Margin="0,0,0,6">
                        <Grid Margin="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="85"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Controller:"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1"
                                       x:Name="MidiCtrlCombo" Width="70"
                                       SelectionChanged="MidiCtrlCombo_SelectionChanged"
                                       Margin="0,2,8,2"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Channel:"/>
                            <ComboBox  Grid.Row="0" Grid.Column="3"
                                       x:Name="MidiChanCombo" Width="70"
                                       SelectionChanged="MidiChanCombo_SelectionChanged"
                                       Margin="0,2,0,2"
                                       HorizontalAlignment="Left"/>

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                        Orientation="Horizontal" Margin="0,2,0,0">
                                <CheckBox x:Name="MidiFeedbackCheck"
                                          Content="Feedback"
                                          Checked="MidiCheck_Changed"
                                          Unchecked="MidiCheck_Changed"
                                          Margin="0,0,12,0"/>
                                <CheckBox x:Name="MidiIncDecCheck"
                                          Content="Inc/Dec (CC 96/97)"
                                          Checked="MidiCheck_Changed"
                                          Unchecked="MidiCheck_Changed"
                                          Margin="0,0,12,0"/>
                                <CheckBox x:Name="MidiWrapCheck"
                                          Content="Wrap"
                                          Checked="MidiCheck_Changed"
                                          Unchecked="MidiCheck_Changed"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <!-- Mapping curve -->
                    <GroupBox Header="Mapping (non-linear curve)" Margin="0,0,0,6">
                        <StackPanel Margin="4">
                            <Border Height="160"
                                    BorderBrush="#555" BorderThickness="1"
                                    Background="#1A1A1A">
                                <local:CurveCanvas x:Name="CurveEditor"/>
                            </Border>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock Text="Left-click=add  Right-click=remove  Drag=move"
                                           Foreground="#666" FontSize="10"
                                           VerticalAlignment="Center"/>
                                <Button Content="Reset to Linear"
                                        Click="BtnResetMapping_Click"
                                        DockPanel.Dock="Right"/>
                            </DockPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- Parameter info -->
                    <GroupBox Header="Parameter Info" Margin="0,0,0,6">
                        <TextBlock x:Name="ParamInfoText"
                                   Text="(select a parameter)"
                                   Foreground="#888" TextWrapping="Wrap"
                                   Margin="4" FontFamily="Consolas" FontSize="11"/>
                    </GroupBox>

                    <Button Content="Update Assignment"
                            Click="BtnUpdate_Click"
                            HorizontalAlignment="Right"
                            Padding="12,4" Margin="0,0,0,4"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ====================================================
             Row 1 – Machine configuration (former "Attributes")
             ==================================================== -->
        <GroupBox Grid.Row="1" Header="Machine Configuration"
                  Margin="0,6,0,0">
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="MIDI Inc/Dec Amount:" Margin="0,0,4,0"/>
                <TextBox x:Name="MidiIncDecAmtBox" Width="64"
                         LostFocus="ConfigBox_LostFocus" Margin="0,0,16,0"/>

                <TextBlock Text="Send Freq (0=tick only):" Margin="0,0,4,0"/>
                <TextBox x:Name="SendFreqBox" Width="40"
                         LostFocus="ConfigBox_LostFocus" Margin="0,0,16,0"/>

                <CheckBox x:Name="StopOnMuteCheck"
                          Content="Stop on mute"
                          Checked="StopOnMuteCheck_Changed"
                          Unchecked="StopOnMuteCheck_Changed"/>
            </StackPanel>
        </GroupBox>

        <!-- ====================================================
             Row 2 – OK / Cancel
             ==================================================== -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK"     Click="BtnOK_Click"     Margin="0,0,6,0"/>
            <Button Content="Cancel" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
